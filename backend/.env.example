# 로컬(설치 0): 이대로 두면 SQLite 파일로 동작
DATABASE_URL=sqlite:///./data/logia.db

# Docker(PostgreSQL) 사용 시 위를 주석 처리하고 아래 사용:
# DATABASE_URL=postgresql+psycopg2://logia:logia@localhost:5432/logia

# 내가(Claude) 요약을 적재할 때 쓰는 간단한 보호 토큰 (아무 문자열)
INGEST_TOKEN=logia-dev-token

# 프론트엔드 주소 (CORS 허용)
FRONTEND_ORIGIN=http://localhost:3000
